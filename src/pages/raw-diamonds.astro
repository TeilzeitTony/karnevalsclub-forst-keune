---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
---

<Layout title="Raw Diamonds">

<PageHero
    title="Raw Diamonds"
    subtitle="Power • Ausdruck • Leidenschaft"
/>

<section class="container">

    <img
        src="/logos/raw-diamonds-header.jpg"
        alt="Raw Diamonds"
        class="page-banner"
    />

    <h2>Über Raw Diamonds</h2>

    <p>
        Die Showdancegruppe Raw Diamonds begeistert seit 1998 mit
        modernen Choreografien, Ausdruck und Leidenschaft.
        Ursprünglich als Cheerleader-Gruppe gegründet,
        gehört Raw Diamonds heute zu den Showtanzgruppen der
        ADTV Tanzschule Fritsche in Cottbus und begeistert
        ihr Publikum mit abwechslungsreichen Shows.
    </p>

</section>

<section class="container">

    <h2>Trainingszeiten</h2>

    <div class="info-box">

        <p><strong>Trainingstag:</strong> Freitag | 20:00 Uhr</p>
        <p><strong>Ort:</strong> ADTV Tanzschule Fritsche, Cottbus</p>

    </div>

</section>

</Layout>