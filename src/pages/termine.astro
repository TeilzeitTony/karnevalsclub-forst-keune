---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
---

<Layout title="Termine">

<PageHero
    title="Termine"
    subtitle="Unsere Veranstaltungen und Auftritte"
    image="/termine-header.jpg"
/>

<section class="container">

    <h2>Kommende Termine</h2>

    <div class="event-highlight">

        <img
            id="eventFlyer"
            src="/events/summer-night-2026.jpg"
            alt="Summer Night 2026"
        />

        <div class="event-card">

            <span class="event-badge">EVENT-HIGHLIGHT</span>

            <h3>🎉 Summer Night 2026</h3>

            <p>
                Freut euch auf einen unvergesslichen Abend mit
                Showprogramm, Musik, guter Stimmung und vielen
                Überraschungen.
            </p>

            <ul class="event-list">
                <li>📅 12.09.2026</li>
                <li>📍 Sportplatz Keune,
                        Schacksdorfer Straße 45
                        in Forst (Lausitz)</li>
                <li>🎭 Showprogramm</li>
                <li>🍻 Essen & Getränke</li>
            </ul>

            <p class="event-note">
                👉 Klickt auf den Flyer, um ihn in voller Größe anzusehen.
            </p>

        </div>

    </div>

    <div id="flyerModal" class="flyer-modal">

        <span class="close-flyer">&times;</span>

        <img
            id="flyerImage"
            src="/events/summer-night-2026.jpg"
            alt="Summer Night 2026"
        />

    </div>

    <div class="event-card future-event">

        <div class="event-date">

            <span class="day">--</span>

            <span class="month">2027</span>

        </div>

        <div class="event-content">

            <h3>Weitere Termine folgen</h3>

            <p>
                Neue Veranstaltungen und Auftritte werden hier
                rechtzeitig veröffentlicht.
            </p>

        </div>

    </div>

</section>

<script>

const flyer = document.getElementById("eventFlyer");
const modal = document.getElementById("flyerModal");
const close = document.querySelector(".close-flyer");

flyer?.addEventListener("click", () => {

    modal.style.display = "flex";

});

close?.addEventListener("click", () => {

    modal.style.display = "none";

});

modal?.addEventListener("click", (e) => {

    if (e.target === modal) {

        modal.style.display = "none";

    }

});

</script>

</Layout>