---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
---

<Layout title="Über unseren Verein">

<PageHero
    title="Karnevalsclub Keune"
    subtitle="Gemeinschaft • Leidenschaft • Tradition"
/>

<section class="container">

    <div class="about-grid">

        <div>

            <img
    src="/icons/verein.jpg"
    alt="Karnevalsclub Keune"
    class="about-image"
/>

        </div>

        <div>

            <h2>Über unseren Verein</h2>

            <p>

                Der Karnevalsclub Forst-Keune wurde im <strong>Juli 2025 </strong>
                als Karnevalssparte des
                <strong> FSV Schwarz-Weiß Keune </strong>
                gegründet.

            </p>

            <p>

                Unser Ziel ist es, Menschen jeden Alters für den Karneval,
                den Tanzsport und das Vereinsleben zu begeistern.

            </p>

            <p>

                Heute gehören bereits rund
                <strong> 30 Mitglieder </strong> 
                zu unserer Gemeinschaft.

            </p>

        </div>

    </div>

</section>

<section class="container">

    <h2 class="facts-heading">Unser Verein auf einen Blick</h2>

    <div class="facts-grid">

        <div class="fact-card">

            <span class="fact-icon">💃</span>

            <h3>4</h3>

            <p>Tanzgruppen</p>

        </div>

        <div class="fact-card">

            <span class="fact-icon">👥</span>

            <h3>30+</h3>

            <p>Mitglieder</p>

        </div>

        <div class="fact-card">

            <span class="fact-icon">📅</span>

            <h3>Juli 2025</h3>

            <p>Gründung</p>

        </div>

        <div class="fact-card motto-card">

            <span class="fact-icon">🎭</span>

            <p class="motto">
                Mit Herz.<br />
                Mit Spaß.<br />
                Mit Leidenschaft.
            </p>

        </div>

    </div>

</section>

<section class="container">

    <h2 class="groups-heading">Unsere Tanzgruppen</h2>

    <div class="timeline">

        <div class="timeline-item">
            <h3>🕺 Forster Männerballett</h3>
            <p>Showtanz mit Leidenschaft und Meisterschaftserfolgen.</p>
        </div>

        <div class="timeline-item">
            <h3>💎 Raw Diamonds</h3>
            <p>Gegründet 1998 – Showtanzgruppe der ADTV Tanzschule Fritsche.</p>
        </div>

        <div class="timeline-item">
            <h3>✨ Blinky Pearls</h3>
            <p>Gegründet 2006 – Showtanzgruppe der ADTV Tanzschule Fritsche.</p>
        </div>

        <div class="timeline-item">
    <h3>👑 Funkengarde</h3>
    <p>
        Trainingsbeginn im Januar 2027 – weitere Informationen folgen in Kürze!
    </p>
</div>

    </div>

</section>

</Layout>