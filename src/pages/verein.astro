---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
---

<Layout title="Über unseren Verein">

<PageHero
    title="Karnevalsclub Keune"
    subtitle="Gemeinschaft • Leidenschaft • Tradition"
/>

<section class="container">

    <div class="about-grid">

        <div>

            <img
    src="/icons/verein.jpg"
    alt="Karnevalsclub Keune"
    class="about-image"
/>

        </div>

        <div>

            <h2>Über unseren Verein</h2>

            <p>

                Der Karnevalsclub Keune wurde im <strong>Juli 2025 </strong>
                als Karnevalssparte des
                <strong> FSV Schwarz-Weiß Keune </strong>
                gegründet.

            </p>

            <p>

                Unser Ziel ist es, Menschen jeden Alters für den Karneval,
                den Tanzsport und das Vereinsleben zu begeistern.

            </p>

            <p>

                Heute gehören bereits rund
                <strong> 30 Mitglieder </strong> 
                zu unserer Gemeinschaft.

            </p>

        </div>

    </div>

</section>

<section class="container">

    <h2>Unsere Tanzgruppen</h2>

    <div class="stats-grid">

        <div class="stat-card">

            <h3>4</h3>

            <p>Tanzgruppen</p>

        </div>

        <div class="stat-card">

            <h3>30+</h3>

            <p>Mitglieder</p>

        </div>

        <div class="stat-card">

            <h3>2025</h3>

            <p>Gründung</p>

        </div>

        <div class="stat-card">

            <h3>1</h3>

            <p>Gemeinschaft</p>

        </div>

    </div>

</section>

<section class="container">

    <h2>Unsere Tanzgruppen</h2>

    <div class="timeline">

        <div class="timeline-item">
            <h3>🕺 Forster Männerballett</h3>
            <p>Showtanz mit Leidenschaft und Meisterschaftserfolgen.</p>
        </div>

        <div class="timeline-item">
            <h3>💎 Raw Diamonds</h3>
            <p>Gegründet 1998 – Showtanzgruppe der ADTV Tanzschule Fritsche.</p>
        </div>

        <div class="timeline-item">
            <h3>✨ Blinky Pearls</h3>
            <p>Gegründet 2006 – Showtanzgruppe der ADTV Tanzschule Fritsche.</p>
        </div>

        <div class="timeline-item">
            <h3>👑 Funkengarde</h3>
            <p>Im Aufbau – wir freuen uns auf neue Mitglieder.</p>
        </div>

    </div>

</section>

</Layout>