---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
---

<Layout title="Funkengarde">

<PageHero
    title="Funkengarde"
    subtitle="Werde Gründungsmitglied!"
    image="/funkengarde-header.jpg"
/>

<section class="container">

    <h2>Unsere Funkengarde entsteht</h2>

    <p>
        Aktuell befindet sich unsere Funkengarde im Aufbau.
        Wir suchen motivierte Tänzerinnen und Tänzer, die Lust haben,
        gemeinsam mit uns etwas Neues aufzubauen und die Zukunft
        unseres Vereins aktiv mitzugestalten.
    </p>

</section>

<section class="container">

    <div class="info-box">

        <h2>Du möchtest dabei sein?</h2>

        <p>
            Dann melde dich bei uns – wir freuen uns auf dich!
        </p>

        <a href="/kontakt" class="button">
            Jetzt Kontakt aufnehmen
        </a>

    </div>

</section>

</Layout>