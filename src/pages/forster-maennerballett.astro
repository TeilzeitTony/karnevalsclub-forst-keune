---
import Gallery from "../components/Gallery.astro";
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
---

<Layout title="Forster Männerballett">

<PageHero
    title="Forster Männerballett"
    subtitle="Leidenschaft • Teamgeist • Show"
    image="/maennerballett-header.jpg"
/>

<section class="container">

    <h2>Aktuelles Programm</h2>

    <div class="program-card">

        <img src="/alice-im-wunderland.jpg" alt="Alice im Wunderland">

        <div class="program-content">

            <span class="program-badge">
                Saison 2026 / 2027
            </span>

            <h3>Alice im Wunderland</h3>

            <p>
                Mit unserem aktuellen Showprogramm entführen wir das Publikum in eine
                fantasievolle Welt voller verrückter Charaktere, beeindruckender
                Kostüme und spektakulärer Choreografien.
            </p>

        </div>

    </div>

</section>

<section class="container">

    <h2>Trainingszeiten</h2>

    <div class="info-box">

        <p><strong>Dienstag</strong></p>
        <p>🕖 19:00 Uhr</p>
        <p>📍 Keune</p>

    </div>

    <div class="info-box" style="margin-top:20px;">

        <p><strong>Sonntag</strong></p>
        <p>🕙 10:00 – 12:00 Uhr</p>
        <p>📍 Tanzschule Fritsche (Cottbus)</p>

    </div>

</section>

<section class="container">

    <h2>Unsere Erfolge</h2>

    <div class="success-grid">

        <div class="success-card">
            <span class="success-icon">🥈</span>
            <h3>Deutscher Vizemeister</h3>
            <p>Hanau 2026</p>
        </div>

        <div class="success-card">
            <span class="success-icon">🏆</span>
            <h3>Ostdeutsche Meisterschaft</h3>
            <p>Erfolgreiche Teilnahme</p>
        </div>

        <div class="success-card">
            <span class="success-icon">📺</span>
            <h3>TV-Auftritt</h3>
            <p>rbb Brandenburg</p>
        </div>

    </div>

</section>

<section class="container">

    <h2>Unsere Tänze</h2>

    <div class="dance-card">

        <img src="/alice-im-wunderland.jpg" alt="Alice im Wunderland" />

        <div class="dance-content">

            <span class="dance-year">2026 / 2027</span>

            <h3>🃏 Alice im Wunderland</h3>

            <p>
                Eine fantasievolle Reise durch das Wunderland mit beeindruckenden
                Kostümen, einzigartigen Charakteren und einer spektakulären
                Showchoreografie.
            </p>

        </div>

    </div>

    <div class="dance-card">

        <img src="/big-in-japan.jpg" alt="Big in Japan" />

        <div class="dance-content">

            <span class="dance-year">2025 / 2026</span>

            <h3>🌸 Big in Japan</h3>

            <p>
                Mit diesem Programm begeisterte das Forster Männerballett Jury und
                Publikum und erreichte den Titel des Deutschen Vizemeisters.
            </p>

        </div>

    </div>

</section>

<Gallery
  title="Bildergalerie"
  images={[
    {
      src: "/galerie/maennerballett/alice1.jpg",
      alt: "Alice im Wunderland",
      width: 1600,
      height: 1067
    },
    {
      src: "/galerie/maennerballett/alice2.jpg",
      alt: "Alice im Wunderland",
      width: 1600,
      height: 1067
    },
    {
      src: "/galerie/maennerballett/alice3.jpg",
      alt: "Alice im Wunderland",
      width: 1600,
      height: 1067
    }
  ]}
/>

</Layout>