---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
---

<Layout title="Blinky Pearls">

<PageHero
    title="Blinky Pearls"
    subtitle="Eleganz • Kreativität • Showdance"
    image="blinkypearls.jpg"
/>

<section class="container">

    <h2>Über die Blinky Pearls</h2>

    <p>
        Die Blinky Pearls wurden im Jahr <strong>2006</strong> gegründet und sind
        eine Showtanzgruppe der <strong>ADTV Tanzschule Fritsche in Cottbus</strong>.
        Mit viel Leidenschaft, Kreativität und Teamgeist entstehen jedes Jahr
        neue Choreografien, die das Publikum begeistern.
    </p>

</section>

<section class="container">

    <h2>Trainingsort</h2>

    <div class="info-box">

        <p><strong>Ort:</strong> ADTV Tanzschule Fritsche</p>
        <p><strong>Stadt:</strong> Cottbus</p>

    </div>

</section>

</Layout>