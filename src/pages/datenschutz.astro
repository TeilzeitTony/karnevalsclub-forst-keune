---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
---

<Layout title="Datenschutz">

<PageHero
    title="Datenschutz"
    subtitle="Datenschutzerklärung"
    image="/kontakt-header.jpg"
/>

<section class="container">

    <h2>Datenschutz</h2>

    <p>

        Die Datenschutzerklärung wird vor der
        Veröffentlichung der Website vollständig
        ergänzt.

    </p>

    <p>

        Nach Einbindung aller Funktionen
        (Instagram, Facebook, Kontaktmöglichkeiten
        usw.) wird diese Seite an die geltenden
        Datenschutzbestimmungen angepasst.

    </p>

</section>

</Layout>