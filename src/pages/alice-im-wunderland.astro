---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import GalleryGrid from "../components/GalleryGrid.astro";
---

<Layout title="Alice im Wunderland">

<PageHero
    title="Alice im Wunderland"
    subtitle="Showprogramm 2026 / 2027"
    image="/galerie/alice/alice1.jpg"
/>
<section class="container">

    <h2>Über das Programm</h2>

    <p>
        Mit „Alice im Wunderland“ entführt das Forster Männerballett sein Publikum
        in eine fantasievolle Welt voller Magie, verrückter Charaktere und
        beeindruckender Choreografien. Farbenfrohe Kostüme, bekannte Figuren
        und jede Menge Humor machen dieses Programm zu einem ganz besonderen
        Erlebnis.
    </p>

</section>

<section class="container">

    <h2>Impressionen aus „Alice im Wunderland“</h2>

    <p class="groups-text">
        Einige Eindrücke aus unserem aktuellen Showprogramm.
    </p>

    <GalleryGrid
        folder="/galerie/alice"
        images={[
            "alice1.jpg",
            "alice2.jpg",
            "alice3.jpg",
            "alice4.jpg",
            "alice5.jpg",
            "alice6.jpg"
        ]}
    />

</section>

<audio id="aliceSound">
    <source src="/sounds/alice.mp3" type="audio/mpeg">
</audio>

</Layout>