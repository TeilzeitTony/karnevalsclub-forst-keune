---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import GalleryGrid from "../components/GalleryGrid.astro";

import alice1 from "../assets/alice/alice1.jpg";
import alice2 from "../assets/alice/alice2.jpg";
import alice3 from "../assets/alice/alice3.jpg";
import alice4 from "../assets/alice/alice4.jpg";
import alice5 from "../assets/alice/alice5.jpg";
import alice6 from "../assets/alice/alice6.jpg";
---

<Layout title="Alice im Wunderland">

<PageHero
    title="Alice im Wunderland"
    subtitle="Showprogramm 2026 / 2027"
    image={alice1.src}
/>

<section class="container">

    <h2>Über das Programm</h2>

    <p>
        Mit „Alice im Wunderland“ entführt das Forster Männerballett sein Publikum
        in eine fantasievolle Welt voller Magie, verrückter Charaktere und
        beeindruckender Choreografien. Farbenfrohe Kostüme, bekannte Figuren
        und jede Menge Humor machen dieses Programm zu einem ganz besonderen
        Erlebnis.
    </p>

</section>

<section class="container">

    <h2>Impressionen aus „Alice im Wunderland“</h2>

    <p class="groups-text">
        Einige Eindrücke aus unserem aktuellen Showprogramm.
    </p>

    <GalleryGrid
        images={[
            alice1,
            alice2,
            alice3,
            alice4,
            alice5,
            alice6
        ]}
    />

</section>

<audio id="aliceSound">
    <source src="/sounds/alice.mp3" type="audio/mpeg">
</audio>

</Layout>