.lightbox-arrow{

    position:absolute;

    top:50%;

    transform:translateY(-50%);

    font-size:70px;

    color:white;

    cursor:pointer;

    user-select:none;

    transition:.3s;

    padding:20px;

}

.lightbox-arrow:hover{

    color:#D4AF37;

}

.left{

    left:40px;

}

.right{

    right:40px;

}