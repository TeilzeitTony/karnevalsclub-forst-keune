---
import posts from "../data/instagram.json";
---

<section class="instagram-gallery">

    <h2>Instagram-Momente</h2>

    <div class="gallery-grid">

        {posts.map((post) => (

            <article class="post-card">

                <img
                    src={post.image}
                    alt={post.title}
                    loading="lazy"
                />

                <div class="content">

                    <h3>{post.title}</h3>

                    <p>{post.caption}</p>

                    <span>{post.date}</span>

                </div>

            </article>

        ))}

    </div>

</section>

<style>

.instagram-gallery{

    margin-top:4rem;

}

.instagram-gallery h2{

    text-align:center;
    color:var(--gold);
    margin-bottom:2rem;

}

.gallery-grid{

    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
    gap:2rem;

}

.post-card{

    background:#111;
    border:1px solid rgba(212,175,55,.25);
    border-radius:18px;
    overflow:hidden;
    transition:.3s;

}

.post-card:hover{

    transform:translateY(-5px);
    border-color:var(--gold);

}

.post-card img{

    width:100%;
    height:260px;
    object-fit:cover;

}

.content{

    padding:1.2rem;

}

.content h3{

    color:var(--gold);
    margin-bottom:.8rem;

}

.content p{

    color:#ddd;
    line-height:1.6;
    margin-bottom:1rem;

}

.content span{

    color:#999;
    font-size:.9rem;

}

</style>