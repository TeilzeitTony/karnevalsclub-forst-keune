---
interface Props {
  title: string;
  subtitle: string;
  image: string;
  leftImage?: string;
  rightImage?: string;
}

const {
  title,
  subtitle,
  image,
  leftImage,
  rightImage
} = Astro.props;
---

<section
  class="page-hero"
  style={`background-image: linear-gradient(rgba(0,0,0,.70), rgba(0,0,0,.70)), url('${image}')`}
>

    <div class="page-hero-content">

        <div class="hero-title-row">

            {leftImage && (
                <img
                    src={leftImage}
                    alt=""
                    class="hero-side-image"
                />
            )}

            <div class="hero-center">

                <h1>{title}</h1>

                <p>{subtitle}</p>

            </div>

            {rightImage && (
                <img
                    src={rightImage}
                    alt=""
                    class="hero-side-image"
                />
            )}

        </div>

    </div>

</section>