---
interface Image {
  src: string;
  alt: string;
}

interface Props {
  title?: string;
  images?: Image[];
}

const {
  title = "Bildergalerie",
  images = []
} = Astro.props;
---

<section class="gallery-section">

    <h2>{title}</h2>

    <div class="gallery-grid">

        {images.map((image) => (

            <img
                src={image.src}
                alt={image.alt}
                loading="lazy"
            />

        ))}

    </div>

</section>