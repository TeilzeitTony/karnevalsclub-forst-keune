---
import PhotoSwipeLightbox from "photoswipe/lightbox";
import "photoswipe/style.css";

const posts = [
  {
    title: "Hallo Forst – wir sind da!",
    caption:
      "Willkommen auf der offiziellen Instagram-Seite des Karnevalsclubs Forst-Keune.",
    date: "04.07.2026",
    image: "/instagram/willkommen.jpg",
    width: 1600,
    height: 1200,
  },
  {
    title: "KCK Summer Night",
    caption:
      "Unsere Summer Night steht vor der Tür. Wir freuen uns auf einen unvergesslichen Abend.",
    date: "12.09.2026",
    image: "/events/summer-night-2026.jpg",
    width: 1600,
    height: 1200,
  },
];
---

<section class="instagram-feed">
  <h2>Instagram-Momente</h2>
  <p class="subtitle">Die neuesten Vereinsmomente.</p>

  <div class="feed-grid" id="instagram-gallery">
    {posts.map((post) => (
      <a
        href={post.image}
        class="feed-card"
        data-pswp-width={post.width}
        data-pswp-height={post.height}
        data-pswp-caption={`${post.title}<br>${post.caption}<br><strong>📅 ${post.date}</strong>`}
      >
        <img src={post.image} alt={post.title} loading="lazy" />
        <div class="overlay">
          <span>{post.date}</span>
        </div>
      </a>
    ))}
  </div>
</section>

<script>
  const lightbox = new PhotoSwipeLightbox({
    gallery: "#instagram-gallery",
    children: "a",
    pswpModule: () => import("photoswipe"),
  });

  lightbox.on("uiRegister", () => {
    lightbox.pswp.ui.registerElement({
      name: "caption",
      order: 9,
      isButton: false,
      appendTo: "root",
      html: "",
      onInit: (el, pswp) => {
        pswp.on("change", () => {
          el.innerHTML =
            pswp.currSlide.data.element.dataset.pswpCaption || "";
        });
      },
    });
  });

  lightbox.init();
</script>

<style>
.instagram-feed{margin-top:5rem}
.instagram-feed h2{
    font-size:2.4rem;
    text-align:center;
    color:#d4af37;
    margin-bottom:.5rem;
    font-weight:700;
    letter-spacing:.5px;
}

.subtitle{
    text-align:center;
    color:#b5b5b5;
    margin-bottom:3rem;
    font-size:1.05rem;
    max-width:700px;
    margin-left:auto;
    margin-right:auto;
    line-height:1.7;
}
.feed-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:32
}
.feed-card{
    position: relative;
    display: block;
    overflow: hidden;

    margin-bottom: 32px;
    break-inside: avoid;

    border-radius: 20px;
    border: 2px solid rgba(212,175,55,.15);

    background: #111;

    box-shadow: 0 12px 35px rgba(0,0,0,.35);

    transition:
        transform .35s ease,
        border-color .35s ease,
        box-shadow .35s ease;

    cursor: pointer;
}

.feed-card::before{
    content:"";
    position:absolute;
    top:0;
    left:-150%;
    width:70%;
    height:100%;
    background:linear-gradient(
        110deg,
        transparent 0%,
        rgba(255,255,255,.08) 35%,
        rgba(212,175,55,.45) 50%,
        rgba(255,255,255,.08) 65%,
        transparent 100%
    );
    transition:left .8s ease;
    z-index:2;
    pointer-events:none;
}

.feed-card:hover::before{
    left:180%;
}

.feed-card:hover{
    transform: translateY(-8px);
    border-color: #d4af37;
    box-shadow:
        0 18px 45px rgba(0,0,0,.45),
        0 0 25px rgba(212,175,55,.18);
}
.feed-card img{
    width:100%;
    height:320px;
    object-fit:cover;
    display:block;
    transition:transform .6s ease;
}

.feed-card:hover img{
    transform:scale(1.1);
    filter:brightness(1.08);
}

.feed-card img{
    width: 100%;
    height: auto;
    display: block;

    transition:
        transform .6s ease,
        filter .6s ease;
}

.feed-card:hover img{
    transform: scale(1.08);
    filter: brightness(1.08);
}

.overlay{
    position:absolute;
    inset:auto 0 0 0;
    padding:22px;
    background:linear-gradient(
        transparent,
        rgba(0,0,0,.92)
    );

    display:flex;
    justify-content:flex-end;
    align-items:flex-end;

    opacity:0;
    transition:opacity .35s ease;
    z-index:3;
}

.feed-card:hover .overlay{
    opacity:1;
}

.overlay span{
    color:#fff;
    font-weight:600;
    font-size:.95rem;
}

.feed-card:hover .overlay{
    opacity:1;
}