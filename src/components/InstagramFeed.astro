---
const posts = [
  {
    title: "Hallo Forst – wir sind da!",
    caption:
      "Willkommen auf der offiziellen Instagram-Seite des Karnevalsclubs Forst-Keune.",
    date: "04.07.2026",
    image: "/instagram/willkommen.jpg",
  },
  {
    title: "KCK Summer Night",
    caption:
      "Unsere Summer Night steht vor der Tür. Wir freuen uns auf einen unvergesslichen Abend.",
    date: "12.09.2026",
    image: "/events/summer-night-2026.jpg",
  },
];
---

<section class="instagram-feed">
  <h2>Instagram-Momente</h2>

  <p class="subtitle">
    Die neuesten Vereinsmomente.
  </p>

  <div class="feed-grid">
    {posts.map((post) => (
      <article class="feed-card">

        <img
          src={post.image}
          alt={post.title}
          loading="lazy"
        />

        <div class="overlay">
          <span>{post.date}</span>
        </div>

        <div class="content">
          <h3>{post.title}</h3>
          <p>{post.caption}</p>
        </div>

      </article>
    ))}
  </div>
</section>

<style>
.instagram-feed{
    margin-top:5rem;
}

.instagram-feed h2{
    font-size:2.4rem;
    text-align:center;
    color:#d4af37;
    margin-bottom:.5rem;
    font-weight:700;
}

.subtitle{
    text-align:center;
    color:#b5b5b5;
    margin-bottom:3rem;
}

.feed-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:32px;
}

.feed-card{
    position:relative;
    overflow:hidden;
    border-radius:20px;
    border:2px solid rgba(212,175,55,.15);
    background:#111;
    transition:.35s;
    box-shadow:0 12px 35px rgba(0,0,0,.35);
}

.feed-card:hover{
    transform:translateY(-8px);
    border-color:#d4af37;
    box-shadow:0 18px 45px rgba(212,175,55,.2);
}

.feed-card img{
    width:100%;
    height:320px;
    object-fit:cover;
    display:block;
    transition:.5s;
}

.feed-card:hover img{
    transform:scale(1.08);
    filter:brightness(1.08);
}

.overlay{
    position:absolute;
    left:0;
    right:0;
    bottom:0;
    padding:18px;
    background:linear-gradient(transparent,rgba(0,0,0,.9));
    color:#fff;
    opacity:0;
    transition:.35s;
}

.feed-card:hover .overlay{
    opacity:1;
}

.content{
    padding:20px;
}

.content h3{
    color:#d4af37;
    margin-bottom:10px;
}

.content p{
    color:#ddd;
    line-height:1.6;
}
</style>